{% comment %}
Swedish Text-TV - Full Layout
X-first full-canvas teletext. The OG retains a compact readable scale.
{% endcomment %}

{% assign page_data = data[0] %}
{% assign page_num = custom_fields.page_number | default: 200 %}

<style>
  .texttv-x {
    align-items: center;
    background: #000;
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    min-height: 100vh;
    overflow: hidden;
    padding: 1rem;
  }
  .texttv-x__page {
    color: #ffff00;
    font-family: 'Courier New', Courier, monospace;
    font-size: clamp(.9rem, 3.3vh, 3rem);
    font-weight: 700;
    line-height: 1.12;
    margin: 0;
    max-width: none;
    transform: scaleX(1.32);
    transform-origin: center;
    white-space: pre;
  }
  .texttv-x__error {
    color: #ffff00;
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.25rem;
    text-align: center;
  }
  @media (min-width: 1200px) {
    .texttv-x { padding: 2.5rem; }
  }
</style>

<div class="view view--full texttv-x">
  {% if page_data.content_plain %}
    <pre class="texttv-x__page">{{ page_data.content_plain }}</pre>
  {% elsif page_data.content %}
    <pre class="texttv-x__page">{{ page_data.content | strip_html }}</pre>
  {% else %}
    <div class="texttv-x__error">
      <div>Text-TV-sidan kunde inte laddas.</div>
      <div>Sida {{ page_num }}</div>
    </div>
  {% endif %}
</div>
