{% comment %}
DN News - Full Layout
X-first editorial layout. Falls back to a compact single column on the OG.
{% endcomment %}

{% assign now_date = 'now' | date: '%s' %}

<style>
  .layout.news-x {
    align-items: stretch;
    display: grid;
    gap: 3cqw;
    grid-template-columns: minmax(0, .95fr) minmax(0, 1.25fr);
    justify-content: stretch;
  }
  .news-x__lead {
    border-right: 2px solid #000;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    padding-right: 3cqw;
  }
  .news-x__kicker, .news-x__time {
    font-size: 1.7cqw;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .news-x__time { margin-top: auto; }
  .news-x__lead-title {
    display: block;
    font-size: 4.4cqw;
    font-weight: 700;
    line-height: 1.08;
    margin: 1.5cqw 0 2cqw;
  }
  .news-x__lead-description {
    font-size: 2.25cqw;
    line-height: 1.25;
  }
  .news-x__list {
    display: grid;
    gap: 2cqh 2cqw;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(5, minmax(0, 1fr));
    min-width: 0;
  }
  .news-x__item {
    border-bottom: 1px solid #000;
    display: flex;
    flex-direction: column;
    gap: 1cqh;
    min-width: 0;
    overflow: hidden;
  }
  .news-x__item-title {
    font-size: 2.25cqw;
    font-weight: 700;
    line-height: 1.15;
  }
  .news-x__item-description {
    font-size: 1.6cqw;
    line-height: 1.25;
  }
</style>

<div class="layout news-x">
  {% if items.size > 0 %}
    {% assign lead = items.first %}
    {% assign lead_timestamp = lead.pubDate | date: '%s' %}
    {% assign lead_elapsed = lead_timestamp | minus: now_date | abs | divided_by: 60 %}
    <article class="news-x__lead">
      <div class="news-x__kicker">Senaste nytt</div>
      <span class="news-x__lead-title">{{ lead.title | strip_html }}</span>
      {% if lead.description != "" %}
        <div class="news-x__lead-description">{{ lead.description | strip_html | truncate: 360 }}</div>
      {% endif %}
      <div class="news-x__time">{{ lead_elapsed }} min sedan</div>
    </article>
    <section class="news-x__list">
      {% for item in items offset: 1 limit: 9 %}
        <article class="news-x__item">
          <span class="news-x__item-title">{{ item.title | strip_html }}</span>
          {% if item.description != "" %}
            <span class="news-x__item-description clamp--2">{{ item.description | strip_html }}</span>
          {% endif %}
        </article>
      {% endfor %}
    </section>
  {% else %}
    <div class="text--sm text--gray-3">Inga nyheter tillgängliga</div>
  {% endif %}
</div>
<div class="title_bar">
  <span class="title">DN.se</span>
  <span class="instance">Uppdaterad {{ 'now' | date: '%Y-%m-%d %H:%M' }}</span>
</div>
